// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================
// ENUMS
// ==========================
enum UserStatus {
  active
  inactive
  suspended
  deleted
}
enum UserRole {
  customer
  service
  kitchen
  manager
  admin
}
enum RestaurantStatus {
  active
  inactive
  suspended
  deleted
}

enum MenuItemStatus {
  active
  inactive
  deleted
}

enum TableStatus {
  empty
  occupied
}

enum OrderStatus {
  pending
  staffConfirmed
  preparing
  ready
  served
  completed
  cancelled
}

enum OrderItemStatus {
  pending
  staffConfirmed
  preparing
  ready
  served
  cancelled
}

enum PaymentMethod {
  cash
  bank
  momo
  vnpay
}

enum PaymentStatus {
  pending
  paid
  failed
}

// ==========================
// MODELS
// ==========================
model Restaurant {
  id           String                 @id @default(uuid())
  name         String
  slug         String                 @unique
  address      String?
  phone        String?
  email        String?
  currency     String                 @default("VND")
  logoUrl      String?
  description  String?
  status       RestaurantStatus       @default(active)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tables       Table[]
  categories   Category[]
  menuItems    MenuItem[]
  orders       Order[]
  payments     Payment[]
  users        User[]
}

model User {
  id           String                 @id @default(uuid())
  name         String
  phone        String?
  email        String?                @unique
  password     String
  refreshToken String?
  avatarUrl    String?
  role         String?                @default("service")
  restaurantId String?
  contractType String?
  address      String?
  status       UserStatus             @default(active)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  restaurant   Restaurant?           @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
}

model Table {
  id           String      @id @default(uuid())
  restaurantId String
  name         String
  qrCode       String      @unique
  status       TableStatus @default(empty)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@unique([restaurantId, name])
  @@index([restaurantId, status])
}

model Category {
  id           String     @id @default(uuid())
  restaurantId String
  name         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
}

model MenuItem {
  id           String         @id @default(uuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Decimal        @db.Decimal(12, 2)
  available    Boolean        @default(true)
  status       MenuItemStatus @default(active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems   OrderItem[]
  images       ImageItem[]
  options      OptionItem[]

  @@index([restaurantId, status])
  @@index([categoryId])
}

model Order {
  id           String      @id @default(uuid())
  restaurantId String
  tableId      String
  status       OrderStatus @default(pending)
  totalAmount  Decimal     @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  items        OrderItem[]
  payments     Payment[]

  @@index([restaurantId, status])
  @@index([tableId, status])
}

model OrderItem {
  id         String          @id @default(uuid())
  orderId    String
  menuItemId String
  name       String
  price      Decimal         @db.Decimal(12, 2)
  quantity   Int             @default(1)
  note       String?
  status     OrderItemStatus @default(pending)
  confirmedBy String?
  confirmedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
}

model Payment {
  id           String        @id @default(uuid())
  restaurantId String
  orderId      String
  method       PaymentMethod
  amount       Decimal       @db.Decimal(12, 2)
  status       PaymentStatus @default(pending)
  paidAt       DateTime?
  image        String?
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status])
  @@index([orderId])
}

model ImageItem {
  id        Int      @id @default(autoincrement())
  menuId    String
  image     String
  createdAt DateTime @default(now())
  menu      MenuItem @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model OptionItem {
  id        Int      @id @default(autoincrement())
  menuId    String
  name      String
  required  Boolean  @default(false)
  createdAt DateTime @default(now())
  menu      MenuItem @relation(fields: [menuId], references: [id], onDelete: Cascade)
}
